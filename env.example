ROCKETRIDE_URI=https://cloud.rocketride.ai
ROCKETRIDE_APIKEY=

# GMI Cloud hosts the Gemini vision model and is used for classification,
# cleanup verification, and the RocketRide dispatch agent.
GMI_API_KEY=
GMI_BASE_URL=https://api.gmi-serving.com/v1
GMI_VISION_MODEL=google/gemini-3.1-flash-lite-preview

# Laptop bridge. For cloud RocketRide, use a public tunnel URL here.
ROCKETRIDE_BRIDGE_COMMAND_URL=http://localhost:8000/robot/command
ROCKETRIDE_BRIDGE_COMMAND_URL_PATTERN=^https?://(localhost|127\.0\.0\.1|.*\.trycloudflare\.com|.*\.ngrok-free\.app|.*\.ngrok\.app)(:\d+)?/robot/command$

# Optional Android status callback fallback. Android can also pass callback_url
# per mission.
ANDROID_STATUS_URL=

# Use "rocketride" to dispatch through the RocketRide HTTP tool node. Use
# "direct" only for local debugging if the RocketRide agent is unavailable.
ROCKETRIDE_DISPATCH_MODE=rocketride
BRIDGE_CALLBACK_TIMEOUT_SECONDS=45
REQUEST_TIMEOUT_SECONDS=30
